FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        python3 \
        python3-pip \
        python3-venv \
        mesa-vulkan-drivers \
        vulkan-tools \
        libxext6 \
        libegl1 \
        libgl1 && \
    rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install \
        --break-system-packages \
        --ignore-installed \
        --no-cache-dir \
        "pip>=25,<26"

WORKDIR /workspace

ARG TORCH_VERSION
ARG TORCH_INDEX_URL
ARG FVDB_CORE_VERSION
ARG FVDB_CORE_INDEX_URL
ARG FVDB_CORE_NIGHTLY=""
ARG FVDB_CORE_NIGHTLY_INDEX_URL=""

RUN if [ -n "$TORCH_INDEX_URL" ]; then \
        python3 -m pip install "torch==${TORCH_VERSION:?TORCH_VERSION build arg is required}" --index-url "${TORCH_INDEX_URL}" --break-system-packages; \
    else \
        python3 -m pip install "torch==${TORCH_VERSION:?TORCH_VERSION build arg is required}" --break-system-packages; \
    fi

# fvdb-core install path:
#   1) FVDB_CORE_NIGHTLY  -> pip install --pre from the upstream nightly simple index.
#   2) otherwise          -> install the pinned FVDB_CORE_VERSION release wheel.
RUN if [ -n "$FVDB_CORE_NIGHTLY" ] && [ "$FVDB_CORE_NIGHTLY" != "0" ]; then \
        : "${FVDB_CORE_NIGHTLY_INDEX_URL:?FVDB_CORE_NIGHTLY_INDEX_URL build arg is required}" && \
        python3 -m pip install --pre \
          "fvdb-core[viewer]" \
          --extra-index-url "${FVDB_CORE_NIGHTLY_INDEX_URL}" \
          --break-system-packages; \
    else \
        python3 -m pip install \
          "fvdb-core[viewer]==${FVDB_CORE_VERSION:?FVDB_CORE_VERSION build arg is required}" \
          --extra-index-url "${FVDB_CORE_INDEX_URL:?FVDB_CORE_INDEX_URL build arg is required}" \
          --break-system-packages; \
    fi && \
    python3 -m pip install numpy pytest --break-system-packages
