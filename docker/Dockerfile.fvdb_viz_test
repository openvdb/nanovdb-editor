FROM nvidia/cuda:12.8.1-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive \
    CUDA_HOME=/usr/local/cuda \
    CUDA_TOOLKIT_ROOT_DIR=/usr/local/cuda \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential \
        git \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        mesa-vulkan-drivers \
        vulkan-tools \
        libxext6 \
        libegl1 \
        libgl1 && \
    rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install \
        --break-system-packages \
        --ignore-installed \
        --no-cache-dir \
        "pip>=25,<26"

WORKDIR /workspace

ARG TORCH_VERSION
ARG TORCH_INDEX_URL
ARG FVDB_CORE_CUDA_ARCH_LIST="7.5;8.0;9.0;10.0;12.0+PTX"
ARG FVDB_CORE_VERSION
ARG FVDB_CORE_INDEX_URL
ARG FVDB_CORE_GIT_REF=""
ARG FVDB_CORE_BUILD_JOBS="1"

RUN if [ -n "$TORCH_INDEX_URL" ]; then \
        python3 -m pip install "torch==${TORCH_VERSION:?TORCH_VERSION build arg is required}" --index-url "${TORCH_INDEX_URL}" --break-system-packages; \
    else \
        python3 -m pip install "torch==${TORCH_VERSION:?TORCH_VERSION build arg is required}" --break-system-packages; \
    fi

RUN if [ -n "$FVDB_CORE_GIT_REF" ]; then \
        TORCH_CUDA_ARCH_LIST="${FVDB_CORE_CUDA_ARCH_LIST}" \
        CMAKE_BUILD_PARALLEL_LEVEL="${FVDB_CORE_BUILD_JOBS}" \
        MAX_JOBS="${FVDB_CORE_BUILD_JOBS}" \
        python3 -m pip install \
          "git+https://github.com/openvdb/fvdb-core.git@${FVDB_CORE_GIT_REF}#egg=fvdb-core[viewer]" \
          --break-system-packages; \
    else \
        python3 -m pip install \
          "fvdb-core[viewer]==${FVDB_CORE_VERSION:?FVDB_CORE_VERSION build arg is required}" \
          --extra-index-url "${FVDB_CORE_INDEX_URL:?FVDB_CORE_INDEX_URL build arg is required}" \
          --break-system-packages; \
    fi && \
    python3 -m pip install numpy pytest --break-system-packages

